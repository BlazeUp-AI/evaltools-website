{
  "name": "llmeval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "preview": "NODE_ENV=production node dist/server/entry-server.js",
    "serve": "NODE_ENV=production tsx server.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "express": "^4.21.0",
    "gsap": "^3.14.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vite": "^6.0.0"
  }
}
